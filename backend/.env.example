# ============ SERVER ============
NODE_ENV=development
PORT=5000
CORS_ORIGIN=http://localhost:5173,http://localhost:8080

# ============ DATABASE ============
MONGODB_URI=mongodb://127.0.0.1:27017/prescription_app

# ============ AUTH ============
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=10

# ============ GEMINI (MULTI-KEY ROTATION) ============
# Comma-separated list of Gemini API keys. The service round-robins and
# fails over to the next key on 429 / quota errors.
GEMINI_API_KEYS=key1_here,key2_here,key3_here
GEMINI_MODEL=gemini-2.0-flash
GEMINI_API_BASE=https://generativelanguage.googleapis.com/v1beta

# ============ RATE LIMIT ============
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

# ============ UPLOADS ============
UPLOAD_DIR=uploads
MAX_UPLOAD_MB=5
